<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>少年殺人事件</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@1&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background-color: #28392e;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      color: rgba(255,255,255,0.88);
      overflow: hidden;
      font-family: 'IM Fell English', Georgia, serif;
    }
    .vignette {
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse at center,
        transparent 72%,
        rgba(0,0,0,0.006) 85%,
        rgba(0,0,0,0.022) 100%
      );
      pointer-events: none;
      z-index: 1;
    }
    #grain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      mix-blend-mode: soft-light;
      opacity: 0.075;
    }
    .container {
      position: relative;
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: clamp(16px, 3vw, 44px);
      padding: 40px 20px;
      flex: 1;
      width: 100%;
    }

    /* 手機：整體往上偏一點讓截圖更好看 */
    @media (max-width: 600px) {
      .container {
        justify-content: center;
        padding-bottom: 80px;
      }
    }

    .logo-link {
      display: block;
      cursor: pointer;
      text-decoration: none;
    }
    .logo-wrap {
      mix-blend-mode: hard-light;
      animation: fadeUpLogo 2s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
      opacity: 0;
    }
    #logoCanvas {
      display: block;
      width: clamp(200px, 72vw, 400px);
      max-width: 88vw;
    }

    .countdown {
      display: flex;
      align-items: flex-start;
      opacity: 0;
      animation: fadeUp 2s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
    }
    .group { display: flex; flex-direction: column; align-items: center; }
    .num {
      font-size: clamp(36px, 10vw, 76px);
      font-weight: 400;
      font-style: italic;
      letter-spacing: 0.02em;
      line-height: 1;
      min-width: 1.6ch;
      text-align: center;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .num.flip { opacity: 0; transform: translateX(5px); }
    #s { transition: opacity 0.08s ease; }
    #s.flip { opacity: 0.7; transform: none; }
    .label {
      font-size: clamp(8px, 2.2vw, 12px);
      letter-spacing: 0.28em;
      margin-top: 8px;
      opacity: 0.6;
      font-style: normal;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .sep {
      font-size: clamp(36px, 10vw, 76px);
      font-style: italic;
      line-height: 1;
      padding: 0 clamp(2px, 1.5vw, 12px);
      padding-bottom: clamp(20px, 5vw, 42px);
      opacity: 0.35;
    }

    footer {
      position: relative;
      z-index: 3;
      padding: 24px;
      font-size: clamp(6px, 0.7vw, 9px);
      letter-spacing: 0.22em;
      opacity: 0;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      font-style: normal;
      text-transform: uppercase;
      animation: fadeIn 2.5s ease 1.5s forwards;
    }

    @keyframes fadeUpLogo {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 0.89; transform: translateY(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 0.5; }
    }
  </style>
</head>
<body>
  <div class="vignette"></div>
  <canvas id="grain"></canvas>

  <div class="container">
    <a class="logo-link" href="https://www.instagram.com/ifeisu_/" target="_blank" rel="noopener">
      <div class="logo-wrap" id="logoWrap">
        <canvas id="logoCanvas"></canvas>
      </div>
    </a>

    <div class="countdown" id="countdown">
      <div class="group">
        <span class="num" id="d">000</span>
        <span class="label">D</span>
      </div>
      <span class="sep">:</span>
      <div class="group">
        <span class="num" id="h">00</span>
        <span class="label">H</span>
      </div>
      <span class="sep">:</span>
      <div class="group">
        <span class="num" id="m">00</span>
        <span class="label">M</span>
      </div>
      <span class="sep">:</span>
      <div class="group">
        <span class="num" id="s">00</span>
        <span class="label">S</span>
      </div>
    </div>
  </div>
  <footer>℗ 2026 Wildflower</footer>

  <script>
    // ── Logo 去背 ──
    const img = new Image();
    img.onload = function() {
      const lc = document.getElementById('logoCanvas');
      lc.width = img.naturalWidth;
      lc.height = img.naturalHeight;
      const ctx = lc.getContext('2d');
      ctx.drawImage(img, 0, 0);
      const data = ctx.getImageData(0, 0, lc.width, lc.height);
      const d = data.data;
      for (let i = 0; i < d.length; i += 4) {
        const brightness = d[i] * 0.299 + d[i+1] * 0.587 + d[i+2] * 0.114;
        d[i+3] = Math.min(255, brightness * 1.6) | 0;
      }
      ctx.putImageData(data, 0, 0);
    };
    img.src = 'data:image/png;base64,';

    // ── Logo wiggle 12fps 卡頓 ──
    const logoWrap = document.getElementById('logoWrap');
    setTimeout(() => {
      setInterval(() => {
        const x = (Math.random() * 2 - 1) * 4;
        const y = (Math.random() * 2 - 1) * 4;
        logoWrap.style.transform = `translate(${x}px, ${y}px)`;
      }, 1000 / 12);
    }, 2400);

    // ── Grain ──
    const grainCanvas = document.getElementById('grain');
    const gctx = grainCanvas.getContext('2d');
    function resizeGrain() {
      grainCanvas.width = window.innerWidth;
      grainCanvas.height = window.innerHeight;
    }
    resizeGrain();
    window.addEventListener('resize', resizeGrain);
    function drawGrain() {
      const w = grainCanvas.width, h = grainCanvas.height;
      const imgd = gctx.createImageData(w, h);
      const px = imgd.data;
      for (let i = 0; i < px.length; i += 4) {
        const v = Math.random() * 255 | 0;
        px[i] = px[i+1] = px[i+2] = v;
        px[i+3] = 255;
      }
      gctx.putImageData(imgd, 0, 0);
      requestAnimationFrame(drawGrain);
    }
    drawGrain();

    // ── 倒數 ──
    const TARGET = new Date('2026-06-15T06:00:00+08:00').getTime();
    function setNum(id, val, pad) {
      const el = document.getElementById(id);
      const next = String(val).padStart(pad, '0');
      if (el.textContent === next) return;
      el.classList.add('flip');
      setTimeout(() => { el.textContent = next; el.classList.remove('flip'); }, 80);
    }
    function tick() {
      const diff = TARGET - Date.now();
      if (diff <= 0) { setNum('d',0,3); setNum('h',0,2); setNum('m',0,2); setNum('s',0,2); return; }
      setNum('d', Math.floor(diff / 86400000), 3);
      setNum('h', Math.floor((diff % 86400000) / 3600000), 2);
      setNum('m', Math.floor((diff % 3600000) / 60000), 2);
      setNum('s', Math.floor((diff % 60000) / 1000), 2);
    }
    tick();
    setInterval(tick, 1000);

    // ── 倒數 wiggle ──
    const el = document.getElementById('countdown');
    let t = Math.random() * 100;
    function noise(t) {
      return Math.sin(t*1.3+0.5)*0.5 + Math.sin(t*2.7+1.2)*0.3 + Math.sin(t*0.9+2.8)*0.2;
    }
    function wiggle() {
      t += 0.022;
      el.style.transform = `translate(${noise(t)*4}px, ${noise(t+50)*4}px)`;
      requestAnimationFrame(wiggle);
    }
    setTimeout(wiggle, 2800);
  </script>
</body>
</html>
