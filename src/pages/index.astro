<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>少年殺人事件</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@1&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
    }
    body {
      background-color: #28392e;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: 100vh;
      color: rgba(255,255,255,0.88);
      font-family: 'IM Fell English', Georgia, serif;
    }
    .vignette {
      position: fixed; inset: 0;
      background: radial-gradient(ellipse at center,
        transparent 72%, rgba(0,0,0,0.006) 85%, rgba(0,0,0,0.022) 100%);
      pointer-events: none; z-index: 1;
    }
    /* grain: CSS size locked via JS, never changes */
    #grain {
      position: fixed; top: 0; left: 0;
      pointer-events: none; z-index: 2;
      mix-blend-mode: soft-light; opacity: 0.074;
      /* width/height set by JS */
    }
    .container {
      position: relative; z-index: 3;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: clamp(16px, 3vw, 44px);
      padding: 40px 20px;
      flex: 1; width: 100%;
    }
    .logo-link { display: block; cursor: pointer; text-decoration: none; }
    .logo-wrap {
      mix-blend-mode: hard-light;
      display: none; opacity: 0;
      transition: opacity 1.6s cubic-bezier(0.16,1,0.3,1);
    }
    #logoCanvas { display: block; width: clamp(200px, 52vw, 420px); max-width: 88vw; }

    .countdown {
      display: flex; align-items: flex-start;
      opacity: 0;
      animation: fadeUp 2s cubic-bezier(0.16,1,0.3,1) 0.9s forwards;
    }
    .group { display: flex; flex-direction: column; align-items: center; }
    .num {
      font-size: clamp(32px, 8vw, 72px);
      font-weight: 400; font-style: italic;
      letter-spacing: 0.02em; line-height: 1;
      min-width: 1.6ch; text-align: center;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .num.flip { opacity: 0; transform: translateX(5px); }
    #s { transition: opacity 0.08s ease; }
    #s.flip { opacity: 0.7; transform: none; }
    .label {
      font-size: clamp(8px, 1.8vw, 12px);
      letter-spacing: 0.28em; margin-top: 8px; opacity: 0.6;
      font-style: normal;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    }
    .sep {
      font-size: clamp(32px, 8vw, 72px);
      font-style: italic; line-height: 1;
      padding: 0 clamp(2px, 1vw, 10px);
      padding-bottom: clamp(18px, 4vw, 40px);
      opacity: 0.35;
    }

    #mysteryPic {
      position: fixed;
      right: clamp(16px, 5vw, 60px);
      bottom: clamp(60px, 14vh, 140px);
      width: clamp(70px, 9vw, 115px);
      cursor: pointer; opacity: 0;
      transition: opacity 1.4s ease;
      filter: saturate(0.8) brightness(0.88);
      z-index: 10;
    }
    #mysteryPic.visible { opacity: 1; }
    #mysteryPic:hover { filter: saturate(0.95) brightness(1); }

    @media (max-width: 600px) {
      #mysteryPic {
        width: clamp(65px, 22vw, 100px);
        right: clamp(12px, 5vw, 28px);
        bottom: clamp(50px, 12vh, 100px);
      }
      .container { padding-bottom: 40px; }
    }

    footer {
      position: relative; z-index: 3; padding: 24px;
      font-size: clamp(6px, 0.7vw, 9px);
      letter-spacing: 0.22em; opacity: 0;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      font-style: normal; text-transform: uppercase;
      animation: fadeIn 2.5s ease 1.5s forwards;
    }

    #overlay {
      position: fixed; inset: 0; background: #000;
      z-index: 100; display: none; flex-direction: column;
      padding: 28px 32px; overflow-y: auto;
    }
    #overlay.open { display: flex; }

    .overlay-nav {
      display: flex; align-items: center;
      gap: 16px; margin-bottom: 36px;
    }
    .overlay-back {
      font-family: 'Courier New', monospace;
      font-size: 13px; color: rgba(255,255,255,0.65);
      cursor: pointer; background: none; border: none;
      letter-spacing: 0.05em; padding: 0;
    }
    .overlay-back:hover { color: white; }
    .overlay-date {
      font-family: 'Courier New', monospace;
      font-size: 13px; color: rgba(255,255,255,0.65);
      letter-spacing: 0.05em;
    }
    .overlay-text {
      font-family: 'Courier New', monospace;
      font-size: clamp(13px, 2vw, 15px);
      color: rgba(255,255,255,0.88);
      line-height: 1.8; margin-bottom: 40px;
    }

    /* album: hidden until 7s, then instant appear — no animation */
    .album-wrap {
      cursor: pointer; display: none;
      position: absolute; z-index: 5;
      width: clamp(56px, 7.7vw, 104px);
    }
    .album-wrap.visible { display: inline-block; }
    .album-wrap img { width: 100%; display: block; transition: opacity 0.2s; }
    .album-wrap:hover img { opacity: 0.8; }

    #albumZoom {
      position: fixed; inset: 0; background: rgba(0,0,0,0.94);
      z-index: 200; display: none;
      align-items: center; justify-content: center; cursor: pointer;
    }
    #albumZoom.open { display: flex; }
    #albumZoom img { max-width: 88vw; max-height: 88vh; object-fit: contain; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 0.5; } }
  
    #credits {
      position: fixed; inset: 0; background: #000;
      z-index: 110; display: none; flex-direction: column;
      padding: clamp(24px,5vw,56px) clamp(28px,6vw,64px);
      overflow-y: auto;
    }
    #credits.open { display: flex; }
    .cr-top {
      display: flex; align-items: baseline;
      justify-content: space-between;
      margin-bottom: clamp(32px,6vh,56px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-bottom: 16px;
    }
    .cr-title {
      font-family: 'Courier New', monospace;
      font-size: 9px; letter-spacing: 0.3em;
      color: rgba(255,255,255,0.15); text-transform: uppercase;
    }
    .cr-back {
      font-family: 'Courier New', monospace;
      font-size: 9px; color: rgba(255,255,255,0.28);
      cursor: pointer; background: none; border: none;
      letter-spacing: 0.18em; padding: 0; text-transform: uppercase;
    }
    .cr-back:hover { color: rgba(255,255,255,0.7); }
    .cr-grid {
      display: grid;
      grid-template-columns: clamp(110px,20vw,200px) 1fr;
      row-gap: 0; column-gap: 0;
    }
    .cr-k {
      font-family: 'Courier New', monospace;
      font-size: clamp(7px,0.8vw,8px);
      color: rgba(255,255,255,0.18);
      text-transform: uppercase; letter-spacing: 0.2em;
      padding: 6px 20px 6px 0;
      border-top: 1px solid rgba(255,255,255,0.04);
      line-height: 1.5; align-self: start;
    }
    .cr-v {
      font-family: 'Courier New', monospace;
      font-size: clamp(8px,0.95vw,10px);
      color: rgba(255,255,255,0.7);
      padding: 6px 0;
      border-top: 1px solid rgba(255,255,255,0.04);
      line-height: 1.8; letter-spacing: 0.04em;
    }
    .cr-r {
      color: rgba(255,255,255,0.16);
      user-select: none; -webkit-user-select: none;
      pointer-events: none;
    }
    .cr-gap { grid-column: 1/-1; height: 10px; }

    #tracklist {
      position: fixed; inset: 0; background: #000;
      z-index: 120; display: none; flex-direction: column;
      padding: clamp(24px,5vw,56px) clamp(28px,6vw,64px);
    }
    #tracklist.open { display: flex; }
    .tl-top {
      display: flex; align-items: baseline;
      justify-content: space-between;
      margin-bottom: clamp(28px,5vh,48px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-bottom: 14px;
    }
    .tl-title-txt {
      font-family: 'Courier New', monospace;
      font-size: 9px; color: rgba(255,255,255,0.15);
      letter-spacing: 0.3em; text-transform: uppercase;
    }
    .tl-back {
      font-family: 'Courier New', monospace;
      font-size: 9px; color: rgba(255,255,255,0.28);
      cursor: pointer; background: none; border: none;
      letter-spacing: 0.18em; padding: 0; text-transform: uppercase;
    }
    .tl-back:hover { color: rgba(255,255,255,0.7); }
    .tl-body {
      flex: 1; display: flex;
      gap: clamp(28px,6vw,80px); align-items: flex-start;
      overflow-y: auto;
    }
    .tl-cover-col { flex-shrink: 0; width: clamp(80px,19vw,210px); }
    .tl-cover-col img { width: 100%; display: block; cursor: zoom-in; transition: opacity 0.2s; }
    .tl-cover-col img:hover { opacity: 0.85; }
    .tl-list {
      font-family: 'Courier New', monospace;
      font-size: clamp(9px,1.1vw,11px);
      color: rgba(255,255,255,0.28);
      line-height: 2.3; letter-spacing: 0.04em; padding-top: 2px;
    }
    .tl-list .tn { color: rgba(255,255,255,0.1); display: inline-block; width: 2.4em; }
    .tl-list .rv { color: rgba(255,255,255,0.78); }
    @media (max-width:600px) {
      .tl-body { flex-direction: column; }
      .tl-cover-col { width: 100%; max-width: 220px; }
    }


    #tlCoverImg.mosaic {
      filter: blur(16px) brightness(0.4) saturate(0.15);
      transform: scale(1.09);
    }
    .tl-cover-col { overflow: hidden; }

    #social {
      position: fixed; inset: 0; background: #000;
      z-index: 115; display: none; flex-direction: column;
      align-items: center; justify-content: center;
      padding: clamp(24px,5vw,56px) clamp(28px,6vw,64px);
    }
    #social.open { display: flex; }
    .soc-back {
      font-family: 'Courier New', monospace;
      font-size: 9px; color: rgba(255,255,255,0.28);
      cursor: pointer; background: none; border: none;
      letter-spacing: 0.18em; padding: 0; text-transform: uppercase;
      position: absolute; top: clamp(24px,5vw,56px); right: clamp(28px,6vw,64px);
    }
    .soc-back:hover { color: rgba(255,255,255,0.7); }
    .soc-links { display: flex; flex-direction: column; gap: 32px; align-items: center; }
    .soc-links a {
      font-family: 'Courier New', monospace;
      font-size: clamp(10px,1.3vw,14px);
      letter-spacing: 0.34em; text-transform: uppercase;
      color: rgba(255,255,255,0.5); text-decoration: none;
      transition: color 0.2s;
    }
    .soc-links a:hover { color: rgba(255,255,255,0.92); }
  </style>
</head>
<body>
  <div class="vignette"></div>
  <canvas id="grain"></canvas>

  <div class="container">
    <div class="logo-link" id="logoLink">
      <div class="logo-wrap" id="logoWrap">
        <canvas id="logoCanvas"></canvas>
      </div>
    </div>
    <div class="countdown" id="countdown">
      <div class="group"><span class="num" id="d">000</span><span class="label">D</span></div>
      <span class="sep">:</span>
      <div class="group"><span class="num" id="h">00</span><span class="label">H</span></div>
      <span class="sep">:</span>
      <div class="group"><span class="num" id="m">00</span><span class="label">M</span></div>
      <span class="sep">:</span>
      <div class="group"><span class="num" id="s">00</span><span class="label">S</span></div>
    </div>
  </div>

  <footer id="socialBtn" style="cursor:pointer;user-select:none;">℗ 2026 Wildflower</footer>
  <img id="mysteryPic" src="data:image/jpeg;base64," alt="" />

  <div id="overlay">
    <div class="overlay-nav">
      <button class="overlay-back" id="overlayBack">←</button>
      <span class="overlay-date">july 15 1987</span>
    </div>
    <div class="overlay-text">我殺了一個人。</div>
    <div class="album-wrap" id="albumWrap">
      <img src="data:image/jpeg;base64," alt="少年殺人事件" />
    </div>
  </div>

  <div id="albumZoom">
    <img src="data:image/jpeg;base64," alt="" />
  </div>

  <script>
    // ── Grain: 初始化一次，CSS size 硬鎖，永遠不動 ──
    const gc = document.getElementById('grain');
    const gctx = gc.getContext('2d');
    const GW = window.innerWidth;
    const GH = window.innerHeight;
    gc.width = GW;
    gc.height = GH;
    gc.style.width = GW + 'px';
    gc.style.height = GH + 'px';

    const SCALE = 2.5;
    const gw = Math.ceil(GW / SCALE);
    const gh = Math.ceil(GH / SCALE);
    // 預先建好 offscreen，固定尺寸
    const grainOff = new OffscreenCanvas(gw, gh);
    const grainOc = grainOff.getContext('2d');

    function drawGrain() {
      const id = grainOc.createImageData(gw, gh);
      const px = id.data;
      for (let i = 0; i < px.length; i += 4) {
        const v = Math.random() * 255 | 0;
        px[i] = px[i+1] = px[i+2] = v; px[i+3] = 255;
      }
      grainOc.putImageData(id, 0, 0);
      gctx.imageSmoothingEnabled = false;
      gctx.drawImage(grainOff, 0, 0, GW, GH);
      requestAnimationFrame(drawGrain);
    }
    drawGrain();

    // ── Logo ──
    const BASE_IMG = new Image();
    BASE_IMG.onload = function() {
      const W = BASE_IMG.naturalWidth, H = BASE_IMG.naturalHeight;
      const off = new OffscreenCanvas(W, H);
      const offCtx = off.getContext('2d');
      offCtx.drawImage(BASE_IMG, 0, 0);
      const raw = offCtx.getImageData(0, 0, W, H);
      const d = raw.data;
      for (let i = 0; i < d.length; i += 4) {
        const b = d[i]*0.299 + d[i+1]*0.587 + d[i+2]*0.114;
        d[i+3] = Math.min(255, b * 1.6) | 0;
      }
      offCtx.putImageData(raw, 0, 0);

      const lc = document.getElementById('logoCanvas');
      lc.width = W; lc.height = H;
      const ctx = lc.getContext('2d');
      ctx.drawImage(off, 0, 0);

      const wrap = document.getElementById('logoWrap');
      wrap.style.display = 'block';
      requestAnimationFrame(() => setTimeout(() => { wrap.style.opacity = '0.89'; }, 50));

      let wiggleOn = false, lastT = 0;
      setTimeout(() => { wiggleOn = true; }, 2400);
      function frame(now) {
        if (wiggleOn && now - lastT >= 210) {
          ctx.clearRect(0, 0, W, H);
          ctx.drawImage(off, (Math.random()*2-1), (Math.random()*2-1));
          lastT = now;
        }
        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    };
    BASE_IMG.src = 'data:image/png;base64,';

    // ── Mystery pic 10s ──
    setTimeout(() => {
      const pic = document.getElementById('mysteryPic');
      const sz = Math.round(Math.min(115, Math.max(70, window.innerWidth * 0.09)));
      pic.style.right = 'auto';
      pic.style.bottom = 'auto';
      pic.style.left = (Math.random() * (window.innerWidth  - sz - 40) + 20) + 'px';
      pic.style.top  = (Math.random() * (window.innerHeight - sz - 80) + 40) + 'px';
      pic.classList.add('visible');
    }, 10000);

    // ── Overlay ──
    let albumTimer = null;
    document.getElementById('mysteryPic').addEventListener('click', () => {
      document.getElementById('overlay').classList.add('open');
      clearTimeout(albumTimer);
      document.getElementById('albumWrap').classList.remove('visible');
      albumTimer = setTimeout(() => {
        const wrap = document.getElementById('albumWrap');
        const sz = Math.round(Math.min(104, Math.max(56, window.innerWidth * 0.077)));
        const x = Math.random() * (window.innerWidth - sz - 60) + 30;
        const y = Math.random() * (window.innerHeight - sz - 60) + 30;
        wrap.style.left = x + 'px';
        wrap.style.top = y + 'px';
        wrap.classList.add('visible');
      }, 2000);
    });
    document.getElementById('overlayBack').addEventListener('click', () => {
      document.getElementById('overlay').classList.remove('open');
      clearTimeout(albumTimer);
    });
    document.getElementById('albumWrap').addEventListener('click', () => {
      document.getElementById('credits').classList.add('open');
    });
    document.getElementById('albumZoom').addEventListener('click', () => {
      document.getElementById('albumZoom').classList.remove('open');
    });

    // ── 倒數 ──
    const TARGET = new Date('2026-06-15T06:00:00+08:00').getTime();
    function setNum(id, val, pad) {
      const el = document.getElementById(id);
      const next = String(val).padStart(pad, '0');
      if (el.textContent === next) return;
      el.classList.add('flip');
      setTimeout(() => { el.textContent = next; el.classList.remove('flip'); }, 80);
    }
    function tick() {
      const diff = TARGET - Date.now();
      if (diff <= 0) { setNum('d',0,3);setNum('h',0,2);setNum('m',0,2);setNum('s',0,2); return; }
      setNum('d', Math.floor(diff/86400000), 3);
      setNum('h', Math.floor((diff%86400000)/3600000), 2);
      setNum('m', Math.floor((diff%3600000)/60000), 2);
      setNum('s', Math.floor((diff%60000)/1000), 2);
    }
    tick(); setInterval(tick, 1000);

    const el = document.getElementById('countdown'); let t = Math.random()*100;
    const noise = t => Math.sin(t*1.3+0.5)*0.5+Math.sin(t*2.7+1.2)*0.3+Math.sin(t*0.9+2.8)*0.2;
    function wiggle() { t+=0.022; el.style.transform=`translate(${noise(t)*4}px,${noise(t+50)*4}px)`; requestAnimationFrame(wiggle); }
    setTimeout(wiggle, 2800);
  
    document.getElementById('logoLink').addEventListener('click', () => {
      const tlImg = document.getElementById('tlCoverImg');
      if (!tlImg.getAttribute('src')) {
        tlImg.src = document.querySelector('#albumZoom img').src;
      }
      tlImg.classList.add('mosaic');
      document.getElementById('tracklist').classList.add('open');
    });
    document.getElementById('socialBtn').addEventListener('click', () => {
      document.getElementById('social').classList.add('open');
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        ['credits','tracklist','albumZoom','social'].forEach(id => {
          document.getElementById(id).classList.remove('open');
        });
      }
    });

  </script>

  <div id="credits">
    <div class="cr-top">
      <span class="cr-title">少年殺人事件 — Credits</span>
      <button class="cr-back" onclick="document.getElementById('credits').classList.remove('open')">← back</button>
    </div>
    <div class="cr-grid">
      <span class="cr-k">Executive Producer</span><span class="cr-v">蘇裔非</span>
      <span class="cr-k">Producer</span><span class="cr-v">蘇裔非 (All Tracks)</span>
      <span class="cr-k">Arrangement</span><span class="cr-v">蘇裔非 (All Tracks)</span>
      <div class="cr-gap"></div>
      <span class="cr-k">Featuring</span><span class="cr-v">Soby, <span class="cr-r">████ ████ █████ █████</span><br><span class="cr-r">███ ████████ ███████ ████████ ██</span>,<br><span class="cr-r">████ ████ ████████ ████████ ████████ ████</span></span>
      <div class="cr-gap"></div>
      <span class="cr-k">Recording</span><span class="cr-v"><span class="cr-r">████████ · ████████████</span></span>
      <span class="cr-k">Mixing</span><span class="cr-v"><span class="cr-r">████████ · ████████████ (Track 4)<br>████████████ (Track 7 & 10)</span></span>
      <span class="cr-k">Mastering</span><span class="cr-v"><span class="cr-r">███████████████</span></span>
      <div class="cr-gap"></div>
      <span class="cr-k">Violin</span><span class="cr-v"><span class="cr-r">████████████</span> (Track 12)</span>
      <span class="cr-k">Guitar</span><span class="cr-v"><span class="cr-r">███████████ (Track 8 & 10) · ████████ (Track 7)</span></span>
      <span class="cr-k">Bass</span><span class="cr-v"><span class="cr-r">█████</span> (Track 8 & 13)</span>
      <span class="cr-k">Saxophone</span><span class="cr-v"><span class="cr-r">███████████</span> (Track 10)</span>
      <div class="cr-gap"></div>
      <span class="cr-k">Creative Dir.</span><span class="cr-v"><span class="cr-r">████████</span></span>
      <span class="cr-k">Cover Design</span><span class="cr-v"><span class="cr-r">████████ · ████ · ████</span></span>
      <span class="cr-k">Photography</span><span class="cr-v"><span class="cr-r">████████</span></span>
      <span class="cr-k">Web Dev.</span><span class="cr-v"><span class="cr-r">████████ · ████████</span></span>
      <div class="cr-gap"></div>
      <span class="cr-k">Story & Concept</span><span class="cr-v">蘇裔非</span>
      <span class="cr-k">Label</span><span class="cr-v">WILDFLOWER</span>
      <span class="cr-k">Distribution</span><span class="cr-v"><span class="cr-r">████████████</span></span>
      <span class="cr-k">Special Thanks</span><span class="cr-v"><span class="cr-r">███████████ · ████ · ████████ · ████████████ · ██████ · ██████ · ██████ · ████████ ·</span> 所有參與這個專案的人 · <span class="cr-r">██████ &lt;3</span></span>
    </div>
  </div>

  <div id="tracklist">
    <div class="tl-top">
      <span class="tl-title-txt">少年殺人事件</span>
      <button class="tl-back" onclick="document.getElementById('tracklist').classList.remove('open')">← back</button>
    </div>
    <div class="tl-body">
      <div class="tl-cover-col">
        <img id="tlCoverImg" src="" alt="" onclick="document.getElementById('albumZoom').classList.add('open')" />
      </div>
      <div class="tl-list">
        <div><span class="tn">01</span><span class="rv">1987</span></div>
